# 【生产】环境变量

# 应用部署基础路径（如部署在子目录 /admin，则设置为 /admin/）
VITE_BASE_URL = /admin/

# API 地址前缀（通过nginx代理）
VITE_API_URL = /api

# 代理目标地址
VITE_API_PROXY_URL = https://6668m.cc

# WebSocket 地址
VITE_WS_URL = wss://6668m.cc/im-ws

# Delete console
VITE_DROP_CONSOLE = true

# 加密密钥（生产环境必须使用强密钥）
VITE_CRYPTO_KEY = art-design-pro-prod-key-2024-secure
